  "type": "module",
  "engines": {
    "bun": ">=1.2.13",
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "type-check": "tsc --noEmit",
    "lint": "biome check --write --unsafe .",
    "lint:check": "biome check .",
    "format": "biome format --write .",
